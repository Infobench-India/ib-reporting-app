{
  "name": "ib-auth-service",
  "version": "1.0.0",
  "description": "Authentication and Authorization service with RBAC support",
  "main": "server.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "start": "set NODE_ENV=production && node server.js",
    "dev": "set NODE_ENV=development && nodemon server.js",
    "build": "pkg server.js --config package.json --targets node18-win-x64 --output ../../deploy/backends/ib-auth-service/dist/server.exe"
  },
  "keywords": ["auth", "rbac", "jwt"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.17.2",
    "compression": "^1.7.0",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.15.4",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^10.0.1",
    "msnodesqlv8": "^4.2.1",
    "moment": "^2.29.4",
    "moment-timezone": "^0.6.0",
    "uuid": "^9.0.1",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "pkg": "^5.8.1",
    "supertest": "^6.3.3"
  }
}
