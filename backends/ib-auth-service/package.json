{
  "name": "ib-auth-service",
  "version": "1.0.0",
  "description": "Authentication and Authorization service with RBAC support",
  "main": "src/server.js",
  "bin": "src/server.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "start": "set NODE_ENV=production && node src/server.js",
    "dev": "set NODE_ENV=development && nodemon src/server.js",
    "build": "pkg . --output dist\\ib-auth-service.exe --targets node18-win-x64 --compress GZip --bytecode",
    "release": "npm run build && xcopy dist\\ib-auth-service.exe ..\\..\\deploy\\backends\\ib-auth-service\\ /Y && \"C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe\" ..\\..\\deploy\\backends\\ib-auth-service\\installer.iss",
    "copy:deploy": "xcopy dist\\ib-auth-service.exe \"C:\\Program Files (x86)\\InfobenchAuthService\" /E /I /Y"
  },
  "keywords": [
    "auth",
    "rbac",
    "jwt"
  ],
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "public.pem",
      ".env.production"
    ]
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.17.2",
    "compression": "^1.7.0",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.15.4",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "moment-timezone": "^0.6.0",
    "mssql": "^10.0.1",
    "node-machine-id": "^1.1.12",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.1",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "pkg": "^5.8.1",
    "supertest": "^6.3.3"
  }
}