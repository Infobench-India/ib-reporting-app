{
  "name": "ib-sql-report-server",
  "version": "1.0.0",
  "description": "Service for executing SQL based reports",
  "bin": "server.js",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "set NODE_ENV=production && node server.js",
    "dev": "set NODE_ENV=development && nodemon server.js",
    "dev-cron": "set NODE_ENV=development && nodemon cron.js",
    "build": "npm run build:server && npm run build:cron",
    "build:server": "pkg server.js --config package.json --targets node18-win-x64 --output ../../deploy/backends/ib-sql-report-server/dist/server.exe",
    "build:cron": "pkg cron.js  --config package.json --targets node18-win-x64 --output ../../deploy/backends/ib-sql-report-server/dist/cron.exe"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pkg": {
    "assets": [
      ".env"
    ]
  },
  "dependencies": {
    "axios": "^1.13.4",
    "body-parser": "^1.17.2",
    "compression": "^1.7.0",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.15.4",
    "moment-timezone": "^0.6.0",
    "msnodesqlv8": "^4.2.1",
    "mssql": "^10.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "pkg": "^5.8.1"
  }
}