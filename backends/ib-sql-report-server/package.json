{
  "name": "ib-sql-report-server",
  "version": "1.0.0",
  "description": "Service for executing SQL based reports",
  "bin": "src/server.js",
  "main": "src/server.js",
  "scripts": {
    "start": "set NODE_ENV=production && node src/server.js",
    "dev": "set NODE_ENV=development && nodemon src/server.js",
    "build": "pkg . --output dist\\ib-sql-report-server.exe --targets node18-win-x64 --compress GZip --bytecode",
    "release": "npm run build && xcopy dist\\ib-sql-report-server.exe ..\\..\\deploy\\backends\\ib-sql-report-server\\ /Y && \"C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe\" ..\\..\\deploy\\backends\\ib-sql-report-server\\installer.iss",
    "copy:deploy": "xcopy dist\\ib-sql-report-server.exe \"C:\\Program Files (x86)\\InfobenchSQLReportService\" /E /I /Y"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "body-parser": "^1.17.2",
    "compression": "^1.7.0",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.15.4",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.6.0",
    "mssql": "^10.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.0",
    "pg": "^8.18.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.3.0",
    "nodemon": "^3.1.10",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      ".env.production",
      "node_modules/tedious/**/*"
    ],
    "scripts": [
      "src/**/*.js"
    ]
  }
}
